   ],
   "source": [
    "# Input from user\n",
    "m = float(input(\"Enter mass kilograms: \"))\n",
    "\n",
    "# Constant value for the speed of Light in m/s\n",
    "c = 29792458\n",
    "\n",
    "# Calculating energy using Einstein equation\n",
    "energy = m * c ** 2\n",
    "\n",
    "print(f\"The energy equivalent to {m} kg of mass is {energy} jouoles.\")"
   ]
