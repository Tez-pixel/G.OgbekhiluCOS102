   "source": [
    "# Simple Interest\n",
    "\n",
    "P = float(input(\"Enter principle amount (P): \"))\n",
    "R = float(input(\"Enter annual Interest Rate (R %): \"))\n",
    "T = float(input(\"Enter time in years (T): \"))\n",
    "\n",
    "A = P * (1 + (R / 100) * T)\n",
    "\n",
    "print(\"Final Amount =\", A)"
   ]
  }
 ],
